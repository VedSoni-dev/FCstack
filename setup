#!/bin/bash
# /fc — FCstack setup
# Copies skill files into ~/.claude/skills/

set -e

SKILLS_DIR="$HOME/.claude/skills"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

SKILLS=("fc" "fc-apply" "fc-interview" "fc-office-hours" "fc-demo-day")

echo ""
echo "  /fc — setting up FCstack skills..."
echo ""

for skill in "${SKILLS[@]}"; do
  mkdir -p "$SKILLS_DIR/$skill"
  cp "$SCRIPT_DIR/skills/$skill/SKILL.md" "$SKILLS_DIR/$skill/SKILL.md"
  echo "  → installed /$skill"
done

echo ""
echo "  ✓ ${#SKILLS[@]} skills installed"
echo ""
echo "  Open any project in Claude Code and run /fc to get started."
echo ""
